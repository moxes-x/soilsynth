EMAIL_SERVER=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=notifications@example.com
EMAIL_PASSWORD=your-app-password
EMAIL_SECURE=false

# Optional SMTP aliases (either EMAIL_* or SMTP_* names can be used)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=
SMTP_USERNAME=
SMTP_PASSWORD=

# Optional generic mail aliases
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_PASSWORD=
MAIL_SECURE=

# Optional AWS SES SMTP aliases
AWS_REGION=
AWS_DEFAULT_REGION=
SES_SMTP_HOST=
SES_SMTP_USER=
SES_SMTP_USERNAME=
SES_SMTP_PASS=
SES_SMTP_PASSWORD=

# Optional SMTP timeout tuning (milliseconds)
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000

ACCESS_TO_EMAIL=team@example.com
ACCESS_FROM_EMAIL=notifications@example.com

NEXT_PUBLIC_ACCESS_ENDPOINT=/api/request-access
